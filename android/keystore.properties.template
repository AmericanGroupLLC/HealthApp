# Upload keystore for Play Store App Signing
# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties — it contains secrets.
#
# To generate a new upload keystore:
#   keytool -genkeypair -v -keystore upload-keystore.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias upload -storepass YOUR_STORE_PASS -keypass YOUR_KEY_PASS

storeFile=upload-keystore.jks
storePassword=
keyAlias=upload
keyPassword=

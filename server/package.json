{
  "name": "myhealth-server",
  "version": "1.0.0",
  "description": "MyHealth backend: auth, profiles, metrics, nutrition, insights, social",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "jest --runInBand --coverage --coverageReporters=lcov --coverageReporters=text-summary",
    "smoke": "node smoke.js"
  },
  "dependencies": {
    "@sentry/node": "^8.42.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "posthog-node": "^4.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "routes/**/*.js",
      "middleware/**/*.js",
      "db.js",
      "server.js",
      "!**/node_modules/**"
    ]
  }
}
